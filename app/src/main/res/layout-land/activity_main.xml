<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0B0014">

    <!-- COLUMNA IZQUIERDA: branding -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0D0020"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RETRO"
            android:textColor="#B84DFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STORE"
            android:textColor="#F2E8FF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="#A020F0"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu tienda de juegos retro"
            android:textColor="#B9A8C9"
            android:textSize="13sp"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <!-- COLUMNA DERECHA: formulario de login -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iniciar sesión"
            android:textColor="#F2E8FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Usuario"
            android:background="@drawable/input_bg"
            android:textColor="#F2E8FF"
            android:textColorHint="#B9A8C9"
            android:padding="12dp"
            android:inputType="text"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contraseña"
            android:background="@drawable/input_bg"
            android:textColor="#F2E8FF"
            android:textColorHint="#B9A8C9"
            android:padding="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtLoginError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="ENTRAR"
            android:backgroundTint="#A020F0"
            android:textColor="#F2E8FF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cuentas: admin/admin123 · user/1234"
            android:textColor="#B9A8C9"
            android:textSize="11sp"
            android:layout_marginTop="14dp" />
    </LinearLayout>

</LinearLayout>
