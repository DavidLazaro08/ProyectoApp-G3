<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0014">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0D0020"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:background="#A020F0"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel de Administrador"
            android:textColor="#F2E8FF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2-column content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IZQUIERDA: imagen preview -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMAGEN DEL JUEGO"
                android:textColor="#B84DFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#2D0B50"
                android:src="@drawable/ic_nav_library"
                android:contentDescription="Preview"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Seleccionar imagen"
                android:backgroundTint="#3D1060"
                android:textColor="#B84DFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- DERECHA: formulario -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A0830"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATOS DEL JUEGO"
                    android:textColor="#B84DFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Título del juego"
                    android:background="@drawable/input_bg"
                    android:textColor="#F2E8FF"
                    android:textColorHint="#B9A8C9"
                    android:padding="12dp"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etCategory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Categoría"
                    android:background="@drawable/input_bg"
                    android:textColor="#F2E8FF"
                    android:textColorHint="#B9A8C9"
                    android:padding="12dp"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Precio (0 = GRATIS)"
                    android:background="@drawable/input_bg"
                    android:textColor="#F2E8FF"
                    android:textColorHint="#B9A8C9"
                    android:padding="12dp"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="Descripción"
                    android:background="@drawable/input_bg"
                    android:textColor="#F2E8FF"
                    android:textColorHint="#B9A8C9"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnSaveProduct"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="PUBLICAR JUEGO"
                    android:backgroundTint="#A020F0"
                    android:textColor="#F2E8FF"
                    android:textStyle="bold"
                    android:textSize="15sp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
