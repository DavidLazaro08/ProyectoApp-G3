<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAME LIBRARY"
            android:textColor="#F2E8FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All games"
            android:textColor="#B84DFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- NEON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A0830"
            android:padding="10dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgNeonStreets"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1.1"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/neon_streets"
                android:contentDescription="Neon Streets Redux" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEON STREETS REDUX"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adventure · €19.99"
                    android:textColor="#B9A8C9"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnAddGame1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Añadir al carrito"
                    android:textColor="#090012"
                    android:backgroundTint="#A020F0" />
            </LinearLayout>
        </LinearLayout>

        <!-- SHADOW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A0830"
            android:padding="10dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgShadowBlade"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1.1"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/shadow_blade"
                android:contentDescription="Shadow Blade DX" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHADOW BLADE DX"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adventure · FREE"
                    android:textColor="#B9A8C9"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnAddGame2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Añadir al carrito"
                    android:textColor="#090012"
                    android:backgroundTint="#A020F0" />
            </LinearLayout>
        </LinearLayout>

        <!-- RETRO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A0830"
            android:padding="10dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgRetroStorm"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1.1"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/retro_storm"
                android:contentDescription="Retro Storm" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RETRO STORM"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fighting · €29.99"
                    android:textColor="#B9A8C9"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnAddGame3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Añadir al carrito"
                    android:textColor="#090012"
                    android:backgroundTint="#A020F0" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnGoCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver carrito"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7A1FD1" />

    </LinearLayout>
</ScrollView>