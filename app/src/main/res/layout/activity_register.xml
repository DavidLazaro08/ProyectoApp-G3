<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/steam_bg"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RETRO STORE"
        android:textColor="@color/steam_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CREAR CUENTA"
        android:textColor="@color/steam_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="28dp" />

    <EditText
        android:id="@+id/etRegUsername"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nombre de usuario"
        android:textColorHint="@color/steam_text_secondary"
        android:textColor="@color/steam_text_primary"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etRegPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contraseña"
        android:textColorHint="@color/steam_text_secondary"
        android:textColor="@color/steam_text_primary"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="textPassword"
        android:maxLines="1"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etRegConfirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Repetir contraseña"
        android:textColorHint="@color/steam_text_secondary"
        android:textColor="@color/steam_text_primary"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="textPassword"
        android:maxLines="1"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtRegError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF5555"
        android:textSize="13sp"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="REGISTRARSE"
        android:textStyle="bold"
        android:backgroundTint="@color/steam_button"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnGoLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Ya tienes cuenta? Iniciar sesión"
        android:textColor="@color/steam_blue"
        android:textSize="14sp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
