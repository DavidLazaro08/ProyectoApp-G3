<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/steam_card"
    android:padding="10dp"
    android:layout_marginBottom="2dp">
    <ImageView android:id="@+id/itemImage" android:layout_width="80dp" android:layout_height="56dp" android:scaleType="centerCrop" android:contentDescription="Game cover" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp" android:paddingEnd="8dp" android:gravity="center_vertical">
        <TextView android:id="@+id/itemTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/steam_text_primary" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
        <TextView android:id="@+id/itemPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/steam_green" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="2dp" />
    </LinearLayout>
    <Button android:id="@+id/itemAddBtn" android:layout_width="44dp" android:layout_height="44dp" android:text="+" android:textSize="20sp" android:backgroundTint="@color/steam_button" android:textColor="#FFFFFF" android:layout_gravity="center_vertical" android:padding="0dp" />
</LinearLayout>
