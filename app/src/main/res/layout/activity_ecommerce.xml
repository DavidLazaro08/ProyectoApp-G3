<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RETRO STORE"
            android:textColor="#F2E8FF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Loading database..."
            android:textColor="#B84DFF"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginBottom="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/neon_streets"
                android:contentDescription="Neon Streets Redux" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● NEW RELEASE"
                android:textColor="#FF3DFF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEON STREETS REDUX"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The definitive 16-bit synthwave odyssey with retro arcade vibes."
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.9   ⬇ 125K   SNES"
                android:textColor="#C84BFF"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POPULAR DOWNLOADS"
            android:textColor="#C84BFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#140022"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> Neon Streets Redux   €19.99"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> Shadow Blade DX   FREE"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> Retro Storm   €29.99"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> Ultra Racer   FREE"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLibrary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="GAME LIBRARY"
            android:textColor="#090012"
            android:backgroundTint="#A020F0" />

        <Button
            android:id="@+id/btnCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="SHOPPING CART"
            android:textColor="#090012"
            android:backgroundTint="#C84BFF" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RETURN TO LOGIN"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4C1D95" />

    </LinearLayout>
</ScrollView>