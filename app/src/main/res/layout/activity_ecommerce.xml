<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RETRO STORE"
            android:textColor="#C84BFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Loading database..."
            android:textColor="#8A2BE2"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#140022"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● NEW RELEASE"
                android:textColor="#FF3DFF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEON STREETS REDUX"
                android:textColor="#E0C3FF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arcade synthwave con estilo retro."
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.9   ⬇ 125K   SNES"
                android:textColor="#C84BFF"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POPULAR DOWNLOADS"
            android:textColor="#C84BFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Neon Streets Redux   €19.99"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Shadow Blade   FREE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Retro Storm   €29.99"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Ultra Racer   FREE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RETURN"
            android:textColor="#0B0014"
            android:backgroundTint="#C84BFF" />

    </LinearLayout>
</ScrollView>