<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="4dp"
                android:layout_height="28dp"
                android:background="#A020F0"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panel de Administrador"
                android:textColor="#F2E8FF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card imagen preview -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMAGEN DEL JUEGO"
                android:textColor="#B84DFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:background="#2D0B50"
                android:src="@drawable/ic_nav_library"
                android:contentDescription="Preview"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Seleccionar imagen"
                android:backgroundTint="#3D1060"
                android:textColor="#B84DFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card datos del juego -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATOS DEL JUEGO"
                android:textColor="#B84DFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Título del juego"
                android:background="@drawable/input_bg"
                android:textColor="#F2E8FF"
                android:textColorHint="#B9A8C9"
                android:padding="12dp"
                android:inputType="textCapWords"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Categoría (Ej: Acción, RPG)"
                android:background="@drawable/input_bg"
                android:textColor="#F2E8FF"
                android:textColorHint="#B9A8C9"
                android:padding="12dp"
                android:inputType="textCapWords"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Precio (0 = GRATIS)"
                android:background="@drawable/input_bg"
                android:textColor="#F2E8FF"
                android:textColorHint="#B9A8C9"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Descripción del juego"
                android:background="@drawable/input_bg"
                android:textColor="#F2E8FF"
                android:textColorHint="#B9A8C9"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

        <!-- Botón guardar -->
        <Button
            android:id="@+id/btnSaveProduct"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="PUBLICAR JUEGO"
            android:backgroundTint="#A020F0"
            android:textColor="#F2E8FF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.08" />

    </LinearLayout>
</ScrollView>
