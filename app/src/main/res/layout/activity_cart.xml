<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHOPPING CART"
            android:textColor="#F2E8FF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/imgCartProduct"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:src="@drawable/retro_storm"
                android:contentDescription="Producto del carrito" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/txtCartItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RETRO STORM"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txtCartPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="€29.99"
                    android:textColor="#B9A8C9"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txtCartQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad: 1"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDER SUMMARY"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtSummaryItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Items: 1"
                android:textColor="#B9A8C9"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtSummarySubtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtotal: €29.99"
                android:textColor="#B9A8C9"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtSummaryTax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tax: €6.30"
                android:textColor="#B9A8C9"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL: €36.29"
                android:textColor="#C84BFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnCheckout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROCEED TO CHECKOUT"
                android:textColor="#090012"
                android:backgroundTint="#A020F0"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBackCatalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONTINUE SHOPPING"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4C1D95" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>