<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/steam_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/steam_header"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAGAR"
            android:textColor="@color/steam_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/steam_surface">

        <TextView
            android:id="@+id/stepCircle1"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold"
            android:background="@drawable/step_active" />
        <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/steam_divider" />
        <TextView
            android:id="@+id/stepCircle2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="2"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold"
            android:background="@drawable/step_inactive" />
        <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/steam_divider" />
        <TextView
            android:id="@+id/stepCircle3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="3"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold"
            android:background="@drawable/step_inactive" />
    </LinearLayout>

    <!-- Step 1: Resumen pedido -->
    <LinearLayout
        android:id="@+id/layoutStep1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESUMEN DEL PEDIDO"
            android:textColor="@color/steam_blue"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtOrderItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/steam_card"
            android:padding="12dp"
            android:textColor="@color/steam_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtCheckoutSubtotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/steam_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtCheckoutTax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/steam_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/steam_divider" />

        <TextView
            android:id="@+id/txtCheckoutTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/steam_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnGoPayment"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CONTINUAR AL PAGO"
            android:textStyle="bold"
            android:backgroundTint="@color/steam_button" />
    </LinearLayout>

    <!-- Step 2: Datos de pago -->
    <LinearLayout
        android:id="@+id/layoutStep2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATOS DE PAGO"
            android:textColor="@color/steam_blue"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- Tarjeta visual en tiempo real -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/previewCardNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="•••• •••• •••• ••••"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/previewCardType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/previewCardName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TITULAR"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/previewCardExpiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MM/AA"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Número de tarjeta con badge de tipo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <EditText
                android:id="@+id/etCardNumber"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Número de tarjeta"
                android:textColorHint="@color/steam_text_secondary"
                android:textColor="@color/steam_text_primary"
                android:background="@null"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:inputType="phone"
                android:maxLength="19"
                android:maxLines="1" />
            <TextView
                android:id="@+id/txtCardType"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingEnd="12dp"
                android:textColor="@color/steam_blue"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etCardName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Titular de la tarjeta"
            android:textColorHint="@color/steam_text_secondary"
            android:textColor="@color/steam_text_primary"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <EditText
                android:id="@+id/etCardExpiry"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="MM/AA"
                android:textColorHint="@color/steam_text_secondary"
                android:textColor="@color/steam_text_primary"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="phone"
                android:maxLength="5"
                android:maxLines="1" />
            <View android:layout_width="8dp" android:layout_height="1dp" />
            <EditText
                android:id="@+id/etCardCvc"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="CVC"
                android:textColorHint="@color/steam_text_secondary"
                android:textColor="@color/steam_text_primary"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="numberPassword"
                android:maxLength="4"
                android:maxLines="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPayError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF5555"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <ProgressBar
            android:id="@+id/progressPay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnConfirmPurchase"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CONFIRMAR COMPRA"
            android:textStyle="bold"
            android:backgroundTint="@color/steam_button" />
    </LinearLayout>

    <!-- Step 3: Éxito -->
    <LinearLayout
        android:id="@+id/layoutStep3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="#00CC66"
            android:textSize="72sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡COMPRA COMPLETADA!"
            android:textColor="@color/steam_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tus juegos ya están en tu biblioteca"
            android:textColor="@color/steam_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnGoHome"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="IR AL INICIO"
            android:textStyle="bold"
            android:backgroundTint="@color/steam_button" />
    </LinearLayout>

</LinearLayout>
